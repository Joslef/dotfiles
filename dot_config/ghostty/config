title = hello!
click-repeat-interval = 500
auto-update-channel = stable
theme = Catppuccin Mocha
font-size = 20
font-family = "FiraCode Nerd Font Mono"
keybind = cmd+k=toggle_command_palette
keybind = opt+cmd++=increase_font_size:1
keybind = opt+cmd+-=decrease_font_size:1
keybind = opt+cmd+0=reset_font_size
keybind = global:ctrl+cmd+#=toggle_quick_terminal
keybind = page_down=scroll_page_lines:10
keybind = page_up=scroll_page_lines:-10
keybind = opt+cmd+r=reload_config
keybind = alt+j=unbind
keybind = alt+k=unbind
macos-option-as-alt = left
cursor-color = #FF27DD
cursor-style-blink = false
shell-integration-features = no-cursor
macos-titlebar-style = hidden
