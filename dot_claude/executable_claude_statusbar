#!/bin/bash
set -f

input=$(cat)

if [ -z "$input" ]; then
    printf "Claude"
    exit 0
fi

blue='\033[38;2;0;153;255m'
orange='\033[38;2;255;176;85m'
cyan='\033[38;2;46;149;153m'
red='\033[38;2;220;50;50m'
white='\033[38;2;220;220;220m'
dim='\033[2m'
reset='\033[0m'

# Returns the escape code for cyan/orange/red based on a percentage value (0-100).
pct_color() {
    local val="$1"
    if [ "$val" -ge 91 ] 2>/dev/null; then
        printf '%b' "$red"
    elif [ "$val" -ge 51 ] 2>/dev/null; then
        printf '%b' "$orange"
    else
        printf '%b' "$cyan"
    fi
}

# Returns the escape code for a thinking effort level string.
effort_color() {
    case "$1" in
        high) printf '%b' "$red" ;;
        medium) printf '%b' "$orange" ;;
        *) printf '%b' "$cyan" ;;  # low, off, or empty
    esac
}

model_name=$(echo "$input" | jq -r '.model.display_name // "Claude"')

# ===== OAuth token =====
get_oauth_token() {
    if [ -n "$CLAUDE_CODE_OAUTH_TOKEN" ]; then
        echo "$CLAUDE_CODE_OAUTH_TOKEN"; return 0
    fi
    local creds_file="${HOME}/.claude/.credentials.json"
    if [ -f "$creds_file" ]; then
        local token
        token=$(jq -r '.claudeAiOauth.accessToken // empty' "$creds_file" 2>/dev/null)
        if [ -n "$token" ] && [ "$token" != "null" ]; then
            echo "$token"; return 0
        fi
    fi
    if command -v secret-tool >/dev/null 2>&1; then
        local blob
        blob=$(timeout 2 secret-tool lookup service "Claude Code-credentials" 2>/dev/null)
        if [ -n "$blob" ]; then
            local token
            token=$(echo "$blob" | jq -r '.claudeAiOauth.accessToken // empty' 2>/dev/null)
            if [ -n "$token" ] && [ "$token" != "null" ]; then
                echo "$token"; return 0
            fi
        fi
    fi
    echo ""
}

# ===== Usage cache =====
cache_file="/tmp/claude/statusline-usage-cache.json"
cache_max_age=60
mkdir -p /tmp/claude

needs_refresh=true
usage_data=""

if [ -f "$cache_file" ]; then
    cache_mtime=$(stat -c %Y "$cache_file" 2>/dev/null)
    now=$(date +%s)
    cache_age=$(( now - cache_mtime ))
    [ "$cache_age" -lt "$cache_max_age" ] && needs_refresh=false && usage_data=$(cat "$cache_file")
fi

if $needs_refresh; then
    token=$(get_oauth_token)
    if [ -n "$token" ] && [ "$token" != "null" ]; then
        response=$(curl -s --max-time 5 \
            -H "Accept: application/json" \
            -H "Content-Type: application/json" \
            -H "Authorization: Bearer $token" \
            -H "anthropic-beta: oauth-2025-04-20" \
            -H "User-Agent: claude-code/2.1.84" \
            "https://api.anthropic.com/api/oauth/usage" 2>/dev/null)
        if [ -n "$response" ] && echo "$response" | jq . >/dev/null 2>&1; then
            usage_data="$response"
            echo "$response" > "$cache_file"
        fi
    fi
    [ -z "$usage_data" ] && [ -f "$cache_file" ] && usage_data=$(cat "$cache_file")
fi

# ===== Format reset time =====
format_reset_time() {
    local iso_str="$1"
    [ -z "$iso_str" ] || [ "$iso_str" = "null" ] && return
    local epoch
    epoch=$(date -d "${iso_str}" +%s 2>/dev/null)
    [ -z "$epoch" ] && return
    LC_ALL=C date -d "@$epoch" +"%H:%M" 2>/dev/null
}

format_reset_datetime() {
    local iso_str="$1"
    [ -z "$iso_str" ] || [ "$iso_str" = "null" ] && return
    local epoch
    epoch=$(date -d "${iso_str}" +%s 2>/dev/null)
    [ -z "$epoch" ] && return
    LC_ALL=C date -d "@$epoch" +"%a %H:%M" 2>/dev/null
}

# ===== Assemble output =====
line="${blue}${model_name}${reset}"

if [ -n "$usage_data" ] && echo "$usage_data" | jq -e . >/dev/null 2>&1; then
    sep=" ${dim}|${reset} "

    five_pct=$(echo "$usage_data" | jq -r '.five_hour.utilization // 0' | awk '{printf "%.0f", $1}')
    five_reset_iso=$(echo "$usage_data" | jq -r '.five_hour.resets_at // empty')
    five_reset=$(format_reset_time "$five_reset_iso")

    seven_pct=$(echo "$usage_data" | jq -r '.seven_day.utilization // 0' | awk '{printf "%.0f", $1}')
    seven_reset_iso=$(echo "$usage_data" | jq -r '.seven_day.resets_at // empty')
    seven_reset=$(format_reset_datetime "$seven_reset_iso")

    five_color=$(pct_color "$five_pct")
    seven_color=$(pct_color "$seven_pct")

    line+="${sep}${five_color}${five_pct}%${reset}"
    [ -n "$five_reset" ] && line+=" ${dim}→${reset} ${cyan}${five_reset}${reset}"

    line+="${sep}${seven_color}${seven_pct}%${reset}"
    [ -n "$seven_reset" ] && line+=" ${dim}→${reset} ${cyan}${seven_reset}${reset}"
fi

# ===== Thinking mode =====
effort=$(jq -r '.effortLevel // empty' "${HOME}/.claude/settings.json" 2>/dev/null)
sep=" ${dim}|${reset} "
effort_val="${effort:-off}"
effort_col=$(effort_color "$effort_val")
line+="${sep}${cyan}thinking: ${effort_col}${effort_val}${reset}"

printf "%b\n" "$line"
exit 0
