{
  "permissions": {
    "allow": [
      "Bash(passwd:*)",
      "Bash(ls:*)",
      "Bash(file-history count:*)",
      "Bash(which ccusage:*)",
      "Bash(head:*)",
      "Bash(find:*)",
      "Bash(playerctl:*)",
      "Bash(waybar:*)",
      "WebSearch",
      "WebFetch(domain:man.archlinux.org)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(pacman:*)",
      "Bash(chmod +x:*)",
      "Bash(hyprctl reload:*)",
      "Bash(brew install:*)",
      "Bash(systemctl --user daemon-reload)",
      "Bash(killall solaar:*)",
      "Bash(systemctl --user restart solaar)",
      "Bash(systemctl --user status solaar)",
      "Bash(journalctl:*)",
      "Skill(update-config)",
      "Bash(grep -E '^bind\\\\s*=\\\\s*\\\\$mainMod[^,]*,' ~/.config/hypr/hyprland.conf)",
      "Bash(grep -oP '\\\\$mainMod[^,]*, \\\\K[^,]+')",
      "WebFetch(domain:github.com)",
      "Bash(gh repo:*)",
      "Bash(snapper --help)",
      "Bash(crontab -l)",
      "Bash(mkdir -p ~/ES-DE/gamelists/pico8)",
      "Bash(mkdir -p ~/ES-DE/downloaded_media/pico8/screenshots)",
      "Bash(hyprctl version:*)",
      "Read(//etc/**)",
      "Read(//etc/snapper/**)",
      "Read(//etc/snapper/configs/**)",
      "Read(//.snapshots/**)",
      "Read(//sysroot/**)",
      "WebFetch(domain:wiki.cachyos.org)",
      "WebFetch(domain:discuss.cachyos.org)",
      "WebFetch(domain:forum.endeavouros.com)",
      "WebFetch(domain:wiki.archlinux.org)",
      "WebFetch(domain:srmsc.org)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p /tmp/claude; _hook=$(cat); _sid=$(printf '%s' \"$_hook\" | jq -r '.session_id // empty'); [ -n \"$_sid\" ] && touch \"/tmp/claude/memory-loaded-$_sid\"; cat ~/.claude/memory/MEMORY.md | jq -Rs '{\"hookSpecificOutput\": {\"hookEventName\": \"SessionStart\", \"additionalContext\": (\"<global-memory>\\n\" + . + \"</global-memory>\")}}'",
            "statusMessage": "**LOADING GLOBAL MEMORY**"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/claude_statusbar"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "cli-anything@cli-anything": true
  },
  "extraKnownMarketplaces": {
    "cli-anything": {
      "source": {
        "source": "github",
        "repo": "HKUDS/CLI-Anything"
      }
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "verbose": true,
  "preferredNotifChannel": "kitty",
  "autoCompactEnabled": false,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "skipAutoPermissionPrompt": true
}
